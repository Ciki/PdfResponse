{
	"name": "jkuchar/pdfresponse",
	"description": "PdfResponse is wrapper of mPDF for Nette.",
	"license": "LGPL-3.0-or-later",
	"scripts": {
		"verify": [
			"@phpstan",
			"@ecs",
			"@rector",
			"@tester"
		],
		"tester": "vendor/bin/tester test",
		"phpstan": "vendor/bin/phpstan analyze -c phpstan.neon --memory-limit 1G",
		"ecs": "vendor/bin/ecs check --ansi",
		"ecs-fix": "vendor/bin/ecs check --fix --ansi",
		"rector": "vendor/bin/rector process --dry-run --ansi",
		"rector-fix": "vendor/bin/rector process --ansi"
	},
	"support": {
		"issues": "https://github.com/Ciki/PdfResponse/issues",
		"source": "https://github.com/Ciki/PdfResponse"
	},
	"authors": [
		{
			"name": "Jan Kuchař",
			"homepage": "http://www.jankuchar.cz",
			"role": "Original author"
		},
		{
			"name": "Ciki",
			"homepage": "https://github.com/Ciki",
			"role": "Maintainer"
		}
	],
	"archive": {
		"exclude": [
			"/.editorconfig",
			"/.github",
			"/.gitignore",
			"/.travis.yml",
			"/ecs.php",
			"/phpstan.neon",
			"/rector.php",
			"/test"
		]
	},
	"autoload": {
		"psr-4": {
			"PdfResponse\\": "src"
		}
	},
	"require": {
		"php": "8.3 - 8.5",
		"ext-dom": "*",
		"ext-libxml": "*",
		"nette/utils": "^4.0",
		"nette/http": "^3.2",
		"nette/application": "^3.1",
		"mpdf/mpdf": "^8.0"
	},
	"require-dev": {
		"nette/tester": "^2.6",
		"phpstan/phpstan": "^2.1",
		"phpstan/phpstan-strict-rules": "^2.0",
		"phpstan/phpstan-deprecation-rules": "^2.0",
		"latte/latte": "^3.0.18",
		"symplify/easy-coding-standard": "^13.0",
		"rector/rector": "^2.0"
	}
}
